# Salin ke mobile-guru/.env (gitignored) atau export saat `expo start`

# Supabase project yang sama dengan backend (demo/prod)
# WAJIB sama dengan NEXT_PUBLIC_SUPABASE_* di .env root repo
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL Next.js (API /api/guru/v1/*)
# Emulator Android: http://10.0.2.2:3001
# Simulator iOS / device di LAN: http://192.168.x.x:3001
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Origin web untuk jembatan OAuth Google (HTTPS publik — wajib untuk dev build & Expo Go).
# Pakai domain APP (bukan marketing www): https://demo.absendik.id
# JANGAN pakai IP LAN (192.168.x.x) atau localhost — Chrome akan gagal (DNS error).
EXPO_PUBLIC_OAUTH_WEB_ORIGIN=https://demo.absendik.id

# Unit AdMob (lihat mobile-guru/src/lib/ads/README.md)
# Kosongkan saat dev → otomatis pakai TestIds Google (aman, tidak melanggar kebijakan).
# WAJIB diisi sebelum rilis production (jangan pakai test id di store).
# Dev build default mematikan native AdMob/UMP agar tidak ada overlay consent yang nge-block layar.
# Set true hanya saat ingin menguji native ads/UMP di dev build.
# EXPO_PUBLIC_ENABLE_NATIVE_ADS=true
# EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-xxx/yyy
# EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-xxx/yyy
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-xxx/yyy
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=ca-app-pub-xxx/yyy
# EXPO_PUBLIC_ADMOB_APP_OPEN_ANDROID=ca-app-pub-xxx/yyy
# EXPO_PUBLIC_ADMOB_APP_OPEN_IOS=ca-app-pub-xxx/yyy

# Langganan Pro — Google Play (Android)
# Product ID harus sama dengan Play Console & backend GURU_IAP_ANDROID_PRODUCT_ID
# EXPO_PUBLIC_GURU_IAP_ANDROID_PRODUCT_ID=guru_pro_monthly
# Dev only (Expo Go): aktifkan Pro tanpa billing — JANGAN set di production build
# EXPO_PUBLIC_GURU_IAP_DEV_UNLOCK=true

# ── Kuota Absendik Guru (fallback offline) ──
# App juga fetch GET /api/guru/v1/quota-config saat startup (prioritas).
# Kosong = default. unlimited / * / -1 = tidak dibatasi.
# EXPO_PUBLIC_GURU_LOCAL_MAX_WORKSPACES=1
# EXPO_PUBLIC_GURU_LOCAL_MAX_CLASSES=5
# EXPO_PUBLIC_GURU_LOCAL_MAX_STUDENTS=120
# EXPO_PUBLIC_GURU_LOCAL_MAX_SUBJECTS=unlimited
# EXPO_PUBLIC_GURU_PRO_MAX_WORKSPACES=unlimited
# EXPO_PUBLIC_GURU_PRO_MAX_CLASSES=unlimited
# EXPO_PUBLIC_GURU_PRO_MAX_STUDENTS=unlimited
# EXPO_PUBLIC_GURU_PRO_MAX_SUBJECTS=unlimited

# Login Google (Supabase → Authentication → Providers → Google)
# Sembunyikan login email/password — default true (hanya Google)
# Set false untuk menampilkan lagi: EXPO_PUBLIC_HIDE_EMAIL_LOGIN=false
# EXPO_PUBLIC_HIDE_EMAIL_LOGIN=true
#
# Google Cloud Console → Credentials → OAuth client (Web application):
#   Authorized redirect URI = https://YOUR-PROJECT.supabase.co/auth/v1/callback
#   (bukan deep link absendikguru:// — itu hanya untuk Supabase Redirect URLs)
#
# Redirect URL (Authentication → URL Configuration):
#   • Expo Go: https://YOUR-DOMAIN/auth/guru/mobile-callback**  (wildcard, sekali saja)
#   • Dev/production build: absendikguru://auth/callback
#   • WAJIB juga: https://YOUR-DOMAIN/auth/guru/mobile-callback**  (jembatan HTTPS → deep link)
#   • EXPO_PUBLIC_OAUTH_WEB_ORIGIN = Site URL Supabase (bukan localhost)
#   • Deploy /auth/guru/mobile-callback sebelum testing OAuth di Expo Go

# UMP / GDPR — hanya untuk pengujian di dev build (jangan set di production)
# Simulasikan lokasi EEA agar form consent muncul:
# EXPO_PUBLIC_ADMOB_CONSENT_DEBUG_GEOGRAPHY=EEA
# EXPO_PUBLIC_ADMOB_TEST_DEVICE_IDS=YOUR-DEVICE-HASH-ID
