{
  "expo": {
    "name": "Catatan Guru",
    "slug": "catatan-guru",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "catatanguru",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.catatanguru.app"
    },
    "android": {
      "package": "com.catatanguru.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#047857"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "catatanguru"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "./plugins/with-kotlin-metadata-compat.js",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      "react-native-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.3.0",
            "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2498265386280857~8098433120",
          "iosAppId": "ca-app-pub-2498265386280857~8235832790",
          "delayAppMeasurementInit": true,
          "userTrackingUsageDescription": "Iklan yang lebih relevan membantu Catatan Guru tetap gratis. Anda bisa menolak tanpa kehilangan fitur."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "a6eae90c-c0eb-43a8-8693-acc336b90d7b"
      }
    },
    "owner": "bytera"
  }
}
